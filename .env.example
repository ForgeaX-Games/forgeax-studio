# ForgeaX configuration. Copy to .env at the repo root and fill in.
#
# Studio dev mode reads its .env at the monorepo root ($ROOT/.env), seeded
# from this file. Edit the live $ROOT/.env to take effect — do not edit
# the example file. Restart the server after changes (bun --watch does not
# auto-reload .env).
#
# Settings drawer (top-right cog in Studio UI) can edit most of these
# interactively too — see packages/server/src/api/settings.ts SAFE_ENV_KEYS.

# ─── Required ─────────────────────────────────────────────────────────────
# Default backend = OpenRouter. Create a key at https://openrouter.ai/keys
# (format sk-or-...), then set the three vars below. claude-code talks to
# OpenRouter's Anthropic skin, so the key goes in ANTHROPIC_AUTH_TOKEN (Bearer)
# and ANTHROPIC_API_KEY MUST stay blank — otherwise claude-code falls back to
# authenticating against api.anthropic.com.
#   guide: https://openrouter.ai/docs/cookbook/coding-agents/claude-code-integration
# The first-run onboarding in the Studio UI writes these three for you too.
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://openrouter.ai/api
ANTHROPIC_API_KEY=

# ─── Optional · model override ────────────────────────────────────────────
# Don't point the default at a cheap non-Anthropic model — Forge relies heavily
# on tool use, which degrades on many providers. Leave unset to use claude-*
# (routed to Anthropic via OpenRouter), or override deliberately.
# FORGEAX_MODEL=claude-haiku-4-5-20251001

# ─── Alternative · bring your own backend (instead of OpenRouter) ──────────
# • Official Anthropic:  set ANTHROPIC_API_KEY=sk-ant-... and blank
#   ANTHROPIC_AUTH_TOKEN + ANTHROPIC_BASE_URL.
# • A private proxy (e.g. litellm): set ANTHROPIC_API_KEY + ANTHROPIC_BASE_URL
#   to the proxy, blank ANTHROPIC_AUTH_TOKEN.
# • A local CLI (claude-code/codex/cursor): just `login` in that CLI — no key
#   here; pick the provider in the ChatPanel composer.

# ─── Optional · OpenAI / Codex / Cursor cli-providers ─────────────────────
# Used by cli-codex / cli-cursor-agent entries when you switch provider in
# the ChatPanel Composer.
# OPENAI_API_KEY=
# OPENAI_BASE_URL=https://api.openai.com/v1
# CURSOR_API_KEY=

# ─── Optional · multimodal image / video keys ─────────────────────────────
# Powers wb-character-forge (character sprite forge) and other wb-* image
# plugins. Primary → fallback chain documented in
# packages/marketplace/plugins/wb-character-forge/DESIGN.md.
#
# 即梦 / Seedream (主立绘路径 · 2k+ image-gen)
#   endpoint: https://ark.cn-beijing.volces.com/api/v3/images/generations
#   注意: size 必须小写 2k/3k/4k 或 WIDTHxHEIGHT · 最小总像素 3,686,400 (≈1920×1920) · 小于则 400
# ARK_IMAGE_KEY=
#
# Gemini nano-banana (主 sprite + 备立绘 · image-gen + image-edit)
#   endpoint: https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash-image:generateContent?key=...
#   注意: key 走 query ?key= 不走 header · 必须设 responseModalities:["IMAGE"]
# GEMINI_API_KEY=
#
# Azure GPT-Image (备 sprite + 备立绘 · image-gen)
#   endpoint: <endpoint>/openai/deployments/<deployment>/images/generations?api-version=2024-02-01
#   注意: header api-key (不是 Bearer) · size 只接受 1024×1024 / 1024×1536 / 1536×1024
# AZURE_GPT_IMAGE_KEY=
# AZURE_GPT_IMAGE_ENDPOINT=https://YOUR-AZURE-RESOURCE.openai.azure.com
# AZURE_GPT_IMAGE_DEPLOYMENT=gpt-image-1
#
# Seedance video (wb-cinematic 视频生成 · 异步 task_id 轮询)
#   endpoint: https://ark.cn-beijing.volces.com/api/v3/contents/generations/tasks
# ARK_VIDEO_KEY=
#
# LiteLLM 私有代理 (含 claude / gpt / gemini / qwen / deepseek 等多家底层模型)
#   endpoint: https://your-litellm-proxy.example.com/v1
#   注意: OpenAI-compat /v1/chat/completions
# LITELLM_PROXY_KEY=
# LITELLM_PROXY_BASE_URL=https://your-litellm-proxy.example.com/v1

# ─── Optional · wb-bgm 音乐/音效库（内网 content server 网关） ─────────────
# Workbench 的 Music & BGM 插件 + Forge 的 search-audio/attach-audio 工具走这个
# 网关拉 BGM/音效。不配则 wb-bgm 后端调用返回 503（不影响 Studio 其余功能）。
# 内网真实地址/凭证只放本机 $ROOT/.env，切勿写进源码或提交。
# WB_BGM_BACKEND_BASE=http://your-internal-content-server/trpc.<service>.http
# WB_BGM_SANDBOX_KEY=your-sandbox-key
# WB_BGM_DEPOT=aw

# ─── Optional · port overrides ────────────────────────────────────────────
# FORGEAX_SERVER_PORT=18900
# FORGEAX_INTERFACE_PORT=18920
# FORGEAX_ENGINE_PORT=15173

# ─── Optional · cli daemon tuning ─────────────────────────────────────────
# SKIP_CLI=1 跳过 forgeax cli 守护进程,只跑 server+interface+engine
# (ChatPanel 这种情况下走 bc / codex 等 subprocess cli-provider)
# SKIP_CLI=0
# FORGEAX_CLI_AUTOSTART=1

# ─── Optional · 人脸打码 (wb-reel 上传 Seedance/Kling 前) ───────────────────
# 2026-06: 本机 Python sidecar (YOLOv8/torch) 已移除; /__ce-api__/face-mask 默认
# 同进程透传 (不打码、不阻断生成). 如需真打码, 自行实现一个纯 TS 的打码服务
# (暴露 POST /mask { image,mode?,halfSide? } → { success,image,faces }), 并设:
# FACE_MASK_SERVICE_URL=http://127.0.0.1:PORT   # 宿主 ce-api-shim 会反代到它
