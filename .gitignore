# Local scratch space (never tracked at parent level)
_drafts/

# Root apps/ was removed — ignore if tooling recreates it (e.g. stray Vite output).
/apps/

# Secrets — even though sub-repos have their own .gitignore, defense-in-depth
.env
.env.*
!.env.example
*.key
key.txt
llm_key.json
github-info.txt

# Build/runtime artifacts
*.log
node_modules/
.forgeax/
/projects/
/state/
/workspace.json
# .forgeax-harness is a floating clone of forgeax-studio-harness (the studio
# closed-loop state repo), NOT a submodule and NOT tracked here. Materialised
# by scripts/sync-harness.mjs (npm run harness:sync / bootstrap.sh / deploy.sh).
/.forgeax-harness/
.self-evolve/
.playwright-mcp/
# playwright-cli session scratch (console logs, snapshot yml, screenshots).
# Produced by forgeax-visual + forgeax-harness/playwright-cli when an agent
# drives a browser. Per-session files (`console-<ts>.log`, `page-<ts>.yml`),
# never useful across sessions.
.playwright-cli/
.forgeax.legacy-backup-*.tar.gz
games/
!packages/games/
test-results/
__pycache__/

# Editor scratch
.vscode/
.idea/
*.swp
.DS_Store
.worktrees/
.bc/
.claude/
# Ad-hoc screenshots dropped at repo root during dev/debug
/wb-*.png
/agent-*.png
/matrix-*.png
MyFile
# 3d-lowpoly agent runtime byproducts + TLS cert export (generated)
/assets/
/library/
forgeax-studio-ca.crt
# Local-only patches handed back to other submodule owners (never upstream)
/.local-patches/
.env8888

# studio-qa automated-test artifacts (screenshots + reports)
/.forgeax-qa/

# studio build output (regenerated)
/packages/studio/dist/
packages/editor
packages/games
packages/marketplace
packages/server

# brainstorming visual companion mockups
.superpowers/

# === 2026-07-05: local-only content (user-directed) ===

# packages/kernel/ — local clone of forgeax-kernel (active platform-io dev);
# not a registered submodule. Keep local, don't clutter status.
/packages/kernel/

# Local analysis / handoff / memory docs (not repo content)
/outputs/
/.workbuddy/

# Local-only helper scripts (not for upstream)
/scripts/build-desktop.sh
/scripts/gen-hellforge-scene-assets.sh
/scripts/gen-hellforge-scene-assets.py

# .cursor/skills/* — local symlinks into vendored skills/ + harness + ~/.cc-switch
# (machine-specific paths, not committable). Keep the tracked real dirs below.
/.cursor/skills/*
!/.cursor/skills/forgeax-editor-ui-pattern/
!/.cursor/skills/forgeax-release/
!/.cursor/skills/update-readme/

# skills/workflow/feature-land — local symlink to ~/.cc-switch (machine-specific)
/skills/workflow/feature-land

# Misc dev artifacts
/turnaround-front-view.png
/turnaround-front.png
/warrior-npu6-req.json
/.tsc-out.txt
