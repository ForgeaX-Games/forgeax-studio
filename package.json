{
  "name": "forgeax-studio",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "description": "ForgeaX Studio — AI-native game development environment",
  "scripts": {
    "harness:sync": "node scripts/sync-harness.mjs",
    "setup": "bun scripts/deploy.ts",
    "bootstrap": "bun scripts/bootstrap.ts",
    "dev": "bun scripts/dev.ts",
    "dev:local": "bun scripts/dev-local.ts",
    "start": "bun scripts/run.ts",
    "stop": "bun scripts/stop.ts",
    "app": "bun scripts/app.ts",
    "web": "bun scripts/open-web.ts",
    "build:plugins": "bun scripts/build-plugins.ts",
    "version": "bun scripts/lib/version.ts",
    "lint:layers": "bun scripts/check-layers.ts --strict",
    "test:layers": "bun test scripts/check-layers.spec.ts",
    "lint:boundaries": "bun run lint:boundaries:core && bun run lint:boundaries:cli && bun run lint:boundaries:agent-host",
    "lint:boundaries:core": "cd packages/core && bun run lint:boundaries",
    "lint:boundaries:cli": "cd packages/cli && bun run lint:boundaries",
    "lint:boundaries:agent-host": "cd packages/agent-host && bun run lint:boundaries"
  },
  "workspaces": [
    "packages/agent-runtime",
    "packages/agent-host",
    "packages/core",
    "packages/host-sdk",
    "packages/kernel/platform-io",
    "packages/interface",
    "packages/interface/packages/design",
    "packages/studio",
    "packages/server",
    "packages/cli",
    "packages/types",
    "packages/editor",
    "packages/editor/packages/editor-core",
    "packages/editor/packages/editor-shared",
    "packages/editor/packages/editor-panels",
    "packages/editor/packages/edit-runtime",
    "packages/editor/packages/play-runtime",
    "packages/engine/packages/*"
  ],
  "comment_dependencies": "react-dom 19 declares scheduler as a peer dep, but bun (≥1.3) does not auto-install peer deps the way npm/pnpm do. Without an explicit dependency here, esbuild fails resolving 'scheduler' from inside react-dom-client.development.js on Windows + bun (Windows GAP-13). Pinning it at the workspace root hoists it where every consumer can find it.",
  "dependencies": {
    "scheduler": "^0.27.0"
  },
  "patchedDependencies": {
    "ink@6.8.0": "patches/ink@6.8.0.patch"
  }
}
