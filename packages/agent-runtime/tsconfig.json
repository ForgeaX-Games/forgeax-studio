{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["bun"],
    "baseUrl": "./src",
    "paths": {
      "@forgeax/types": ["../../types/src/index.ts"],
      "@forgeax/types/*": ["../../types/src/*"]
    }
  },
  "include": ["src", "test"]
}
