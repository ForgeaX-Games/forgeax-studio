{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "allowSyntheticDefaultImports": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["bun"],
    "baseUrl": "./src",
    "paths": {
      "@forgeax/agent-runtime": ["../../contracts/agent-runtime/src/index.ts"],
      "@forgeax/agent-runtime/*": ["../../contracts/agent-runtime/src/*"],
      "@forgeax/types": ["../../contracts/types/src/index.ts"],
      "@forgeax/types/*": ["../../contracts/types/src/*"]
    }
  },
  "include": ["src", "test", "scripts"]
}
