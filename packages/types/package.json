{
  "name": "@forgeax/types",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared zod schemas + TS contracts for forgeax-plugin.json, agent/skill/tool/host-sdk. Single source of truth for plugin manifest validation across server / interface / cli.",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./manifest": "./src/manifest.ts",
    "./agent": "./src/agent.ts",
    "./skill": "./src/skill.ts",
    "./tool": "./src/tool.ts",
    "./host-sdk": "./src/host-sdk.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "validate-manifests": "bun test/validate-manifests.ts"
  },
  "dependencies": {
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "typescript": "^5.6.3"
  }
}
